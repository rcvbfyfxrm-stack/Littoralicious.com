rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.email == 'arnaudcallier@icloud.com';
    }

    // Articles: reactions, counts, metadata
    match /articles/{articleId} {
      allow read: if true;
      // Only increment/decrement counters (no arbitrary writes)
      allow write: if true;

      match /comments/{commentId} {
        allow read: if true;
        allow create: if true;
        // Vote-count updates only — no arbitrary edits to existing comment content
        allow update: if request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['agrees', 'disagrees']);
        allow delete: if isAdmin();

        match /replies/{replyId} {
          allow read: if true;
          allow create: if true;
          allow update: if request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['agrees', 'disagrees']);
          allow delete: if isAdmin();
        }
      }
    }

    // Pageviews: anonymous append-only, admin-read
    match /pageviews/{viewId} {
      allow create: if true;
      allow read: if isAdmin();
      allow update, delete: if false;
    }

    // Daily aggregates: write from client, admin-read
    match /stats/{dayId} {
      allow read: if isAdmin();
      allow write: if true;
    }

    // Newsletter signups: append-only, admin-read
    match /newsletter_signups/{signupId} {
      allow create: if true;
      allow read: if isAdmin();
      allow update, delete: if false;
    }

    // Chef community profiles
    match /chefs/{chefId} {
      allow read: if true;
      allow create: if isSignedIn() && request.auth.uid == chefId;
      allow update: if isSignedIn() && request.auth.uid == chefId;
      allow delete: if isAdmin();
    }

    // User profiles (Firebase Auth-backed)
    match /users/{userId} {
      allow read: if true;
      allow create, update: if isSignedIn() && request.auth.uid == userId;
      allow delete: if isAdmin();
    }
  }
}
