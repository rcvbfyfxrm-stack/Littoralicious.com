rules_version = '2';

// Littoralicious Firestore security rules.
// Two surfaces:
//   articles/**     — public publication engagement (reactions, comments, replies).
//                     Kept open to preserve the existing community features (community.js).
//   draft-notes/**  — PRIVATE review notes on drafts. Reviewer allowlist only.
//
// Deploy with:  firebase deploy --only firestore:rules
// (firebase.json must contain a "firestore": { "rules": "firestore.rules" } block.)

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Reviewer allowlist — EDIT THESE EMAILS ──────────────────────────────
    function isReviewer() {
      return request.auth != null && request.auth.token.email in [
        'arnaudcallier@pm.me',
        'arnaudcallier@icloud.com'
        // add reviewer emails here
      ];
    }

    // ── Public: live-article engagement (unchanged behaviour) ───────────────
    // Open read/write so existing reactions/comments keep working with no auth.
    // Tighten later if abused; do NOT remove without migrating community.js.
    match /articles/{slug}/{document=**} {
      allow read, write: if true;
    }

    // ── Private: draft review notes ─────────────────────────────────────────
    match /draft-notes/{slug} {
      allow read, write: if isReviewer();

      match /notes/{noteId} {
        allow read:   if isReviewer();
        allow create: if isReviewer()
                      && request.resource.data.text is string
                      && request.resource.data.text.size() > 0
                      && request.resource.data.text.size() < 5000;
        allow update, delete: if isReviewer();
      }
    }

    // ── Public: terroir guides — ♡ loves, legacy votes, reader comments ─────
    // Unlisted, robots-blocked archive. Loves/votes are monotonic counter docs;
    // kept open like articles/** above (same risk posture) so the ♡ counts +
    // the vote-driven "blue top-3" actually work.
    match /terroir_loves/{slug}            { allow read, write: if true; }
    match /terroir_votes/{slug}/{doc=**}   { allow read, write: if true; }
    match /terroir_inventory_votes/{slug}  { allow read, write: if true; }

    // Reader comments: terroir_comments/<slug>/comments/<autoId> = {name, text, ts}.
    // Read open; create only with validated shape; no client update/delete (moderate in console).
    match /terroir_comments/{slug}/comments/{commentId} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasOnly(['name','text','ts'])
                    && request.resource.data.name is string
                    && request.resource.data.name.size() <= 40
                    && request.resource.data.text is string
                    && request.resource.data.text.size() >= 3
                    && request.resource.data.text.size() <= 600
                    && request.resource.data.ts == request.time;
      allow update, delete: if false;
    }

    // ── Default deny (no-op alongside the explicit allows above) ────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
